modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/easyboard"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 25532
externalPort = 80

[userenv]

# Secrets (SEED_PASSWORD for demo mode, SESSION_SECRET, ANTHROPIC_API_KEY) are
# never committed — set them in Replit Secrets or the environment.
# DEMO_MODE=true opts into seeding the Meridian demo dataset.
[userenv.shared]
