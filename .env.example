# LQGovernance — Board Management Portal — environment configuration.
# Copy to `.env` (`cp .env.example .env`) and fill in the values below.
# The server and drizzle-kit load this file automatically from the repo root.
# Real environment variables set by your shell / container always take precedence.

# ── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string. Matches the bundled docker-compose service.
DATABASE_URL=postgresql://openboard:openboard@localhost:5432/openboard

# Signs JWT session tokens. The server refuses to start without it.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=

# Keys the integrity layer: HMACs the audit chain and wraps the server's
# Ed25519 certificate-signing key. Required in production (min 32 chars);
# without it (dev only) the audit chain is unkeyed sha256 and vote
# certificates fall back to the legacy unsigned format. Keep it OUT of the
# database and its backups — the tamper-evidence claims rest on that
# separation. Generate one with: openssl rand -hex 32
SERVER_SIGNING_SECRET=

# API server port.
PORT=3000

# ── Frontend (dev) ──────────────────────────────────────────────────────────

# Port for the Vite dev/preview server. Kept separate from PORT so the API and
# the frontend can run side by side. The dev server proxies /api to the API.
WEB_PORT=5173

# Base path the SPA is served under. Leave as "/" unless hosting under a sub-path.
BASE_PATH=/

# Where the Vite dev server proxies /api during `pnpm dev`. Defaults to the API
# on http://localhost:${PORT}; only change it if the API runs elsewhere.
# API_PROXY_TARGET=http://localhost:3000

# ── AI (optional — the app works without a provider; AI features are disabled) ─

# Provider: "anthropic" or "openai-compatible" for local inference against any
# /v1/chat/completions server (Ollama, vLLM, LM Studio, llama.cpp…). The local
# provider keeps document text on your infrastructure; Anthropic does not.
# AI_PROVIDER=anthropic

# ⚠ EXTERNAL EGRESS ACKNOWLEDGEMENT (P0.4). The Anthropic provider transmits
# extracted document text — including passages the classifier flags as
# privileged — OFF this deployment. That path is DISABLED until you set this to
# "true", even if a key is present. The local provider does not require it.
# AI_ALLOW_EXTERNAL_PROVIDER=true

# Anthropic API key (anthropic provider). Enables classification, search,
# suggestions — but only together with AI_ALLOW_EXTERNAL_PROVIDER=true above.
# AI_INTEGRATIONS_ANTHROPIC_API_KEY takes precedence over ANTHROPIC_API_KEY if both are set.
ANTHROPIC_API_KEY=
# AI_INTEGRATIONS_ANTHROPIC_API_KEY=

# openai-compatible provider: the server's OpenAI-compatible root (required for
# that provider; requests go to $AI_BASE_URL/chat/completions) and an optional
# bearer token if your server needs one.
# AI_BASE_URL=http://localhost:11434/v1
# AI_API_KEY=

# Heavy model — classification + natural-language commands (extended thinking on
# Anthropic). On openai-compatible, use a model name your server hosts.
AI_MODEL=claude-opus-4-8

# Light model — search, suggestions, and evidence review (cheaper, no thinking).
AI_LIGHT_MODEL=claude-haiku-4-5-20251001

# Daily ceiling on AI calls (cost guard; persisted, restart-safe).
AI_DAILY_CALL_LIMIT=1000

# Optional daily token ceiling (off by default).
# AI_DAILY_TOKEN_LIMIT=

# Point at an Anthropic-compatible gateway to self-host the endpoint (optional).
# AI_INTEGRATIONS_ANTHROPIC_BASE_URL=

# ── Security: two-factor authentication (P0.2) ────────────────────────────────

# TOTP MFA is built in and requires no configuration. It is MANDATORY for admins
# and any board member who can vote or sign, and it is re-verified before the
# organization-binding actions (signing minutes, approving AI proposals,
# exporting the full record). Users enroll an authenticator app in their account
# settings; recovery codes are issued once and stored only as hashes.

# How recently the second factor must have been proven for those binding actions,
# in seconds. Default 900 (15 min). Lower it for a stricter re-verification
# cadence; raise it for fewer prompts.
# MFA_FRESHNESS_SECONDS=900

# ── Email (optional — password reset / account invite delivery) ───────────────

# SMTP server for outbound email. When SMTP_HOST is unset, email is disabled and
# password-reset links are written to the server log only (exactly the previous
# behavior). Setting it enables: the forgot-password reset email, and an
# invite-style "set your password" email for admin-created accounts.
# The first-boot admin one-time password is ALWAYS log-only.
# SMTP_HOST=smtp.yourprovider.com

# SMTP port. 587 (STARTTLS, the default) or 465 (implicit TLS with SMTP_SECURE).
# SMTP_PORT=587

# "true" for implicit TLS (port 465). Leave unset for STARTTLS on 587.
# SMTP_SECURE=false

# SMTP credentials (omit both for an unauthenticated relay).
# SMTP_USER=
# SMTP_PASS=

# From address for outbound mail. Defaults to SMTP_USER.
# SMTP_FROM=board@yourcompany.com

# Public base URL of the frontend, used to build reset links in emails.
# Defaults to http://localhost:5173 (dev). Set it in any real deployment.
# APP_BASE_URL=https://board.yourcompany.com

# ── Production / deployment ───────────────────────────────────────────────────

# Set to "production" for secure cookies and to require ALLOWED_ORIGIN.
# NODE_ENV=production

# REQUIRED in production: comma-separated allowlist of frontend origins for CORS.
# In development the app accepts localhost only.
# ALLOWED_ORIGIN=https://board.yourcompany.com

# Automatic HTTPS (the `production` docker compose profile): your domain (DNS must
# point at the host; ports 80+443 open) and an email for the Let's Encrypt account.
# DOMAIN=board.yourcompany.com
# ACME_EMAIL=you@yourcompany.com

# The compose app port binds to loopback (127.0.0.1) by default — reachable at
# http://localhost:${APP_PORT}, and Caddy proxies it in production. Set this to
# 0.0.0.0 ONLY to expose the app directly on all interfaces (no reverse proxy).
# APP_BIND=0.0.0.0

# The Docker image serves the built SPA from the API and sets STATIC_DIR itself.
# Only set this for a bare-metal single-process run (path to easyboard/dist/public).
# STATIC_DIR=

# First-boot admin account (used when DEMO_MODE is unset). A random one-time
# password is printed to the server log on first boot.
ADMIN_EMAIL=admin@openboard.local
ORG_NAME=My Organization

# Log verbosity (trace|debug|info|warn|error). Default: info.
# LOG_LEVEL=info

# Version string reported by the system endpoint. Defaults to the app version.
# APP_VERSION=

# ── Demo dataset (optional — NEVER enable in production) ───────────────────────

# "true" seeds the fictional Meridian Energy Group demo (20 users, 5 boards).
# DEMO_MODE=true

# Shared password for the demo accounts (only used when DEMO_MODE=true).
# SEED_PASSWORD=

# Safety interlock for the demo reset. When DEMO_MODE=true and no demo dataset
# is found, seeding wipes ALL data. If the database is NOT empty, that wipe is
# refused unless you explicitly confirm it here. Leave unset in normal use.
# DEMO_MODE_FORCE_WIPE=true
